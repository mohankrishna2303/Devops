# AI CI/CD Failure Intelligence Platform
# Production Configuration Template

# 1. AI Engine (OpenAI)
OPENAI_API_KEY=your_openai_api_key_here

# 2. Alerting (Slack)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/T.../B.../X...

# 3. Security
GITHUB_WEBHOOK_SECRET=your_custom_secret_for_signature_verification
DEBUG=True

# 4. Database (Defaults to SQLite if not provided)
# DB_NAME=devops_intel
# DB_USER=admin
# DB_PASSWORD=pass
# DB_HOST=localhost

# 5. Social OAuth Configuration
GOOGLE_OAUTH_CLIENT_ID=your_google_client_id
GOOGLE_OAUTH_CLIENT_SECRET=your_google_client_secret

GITHUB_OAUTH_CLIENT_ID=your_github_client_id
GITHUB_OAUTH_CLIENT_SECRET=your_github_client_secret

GITLAB_OAUTH_CLIENT_ID=your_gitlab_client_id
GITLAB_OAUTH_CLIENT_SECRET=your_gitlab_client_secret

BITBUCKET_OAUTH_CLIENT_ID=your_bitbucket_client_id
BITBUCKET_OAUTH_CLIENT_SECRET=your_bitbucket_client_secret

# 6. Frontend URL for OAuth redirects
FRONTEND_URL=http://localhost:5174
