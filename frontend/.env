# Backend API base URL (no trailing slash). Used by api.js and authService.
VITE_API_URL=http://localhost:8000/api

# OpenAI API Key for ChatGPT integration
# Get your API key from: https://platform.openai.com/api-keys
VITE_OPENAI_API_KEY=sk-test-key-placeholder

# AWS Credentials
# Get your credentials from: https://console.aws.amazon.com/iam/home
AWS_ACCESS_KEY_ID=your_aws_access_key_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_key_here
AWS_REGION=us-west-2
AWS_SESSION_TOKEN=your_aws_session_token_here

# Azure Credentials
# Get your credentials from: https://portal.azure.com/#blade/Microsoft_AAD_IAM/ActiveDirectoryMenuBlade/Properties
AZURE_SUBSCRIPTION_ID=your_azure_subscription_id_here
AZURE_CLIENT_ID=your_azure_client_id_here
AZURE_CLIENT_SECRET=your_azure_client_secret_here
AZURE_TENANT_ID=your_azure_tenant_id_here

# Google Cloud Platform Credentials
# Get your credentials from: https://console.cloud.google.com/iam-admin/serviceaccounts
GCP_PROJECT_ID=your_gcp_project_id_here
GCP_CREDENTIALS=path/to/your/service-account-key.json
GCP_REGION=us-central1

# Terraform Configuration
TERRAFORM_VERSION=1.5.0
TERRAFORM_WORKSPACE=default

# Database Configuration
DATABASE_TYPE=sqlite
DATABASE_URL=./database/devops.db

# Additional environment variables
VITE_APP_NAME=DevOps Dashboard
VITE_APP_VERSION=1.0.0
